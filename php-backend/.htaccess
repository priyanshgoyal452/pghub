RewriteEngine On
RewriteBase /pghub/php-backend/

# ── Security: Block access to sensitive files ──
RewriteRule ^\.env$ - [F,L]
RewriteRule ^\.git - [F,L]
RewriteRule ^\.htaccess$ - [F,L]
RewriteRule \.sql$ - [F,L]

# ── Security: Block direct access to internal PHP files ──
# Only allow index.php to be executed directly
RewriteCond %{REQUEST_URI} \.php$
RewriteCond %{REQUEST_URI} !/index\.php$
RewriteRule ^ - [F,L]

# ── Pass Authorization header through to PHP (Apache strips it by default) ──
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Serve real files/dirs as-is (uploads, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else through index.php
RewriteRule ^(.*)$ index.php [QSA,L]
